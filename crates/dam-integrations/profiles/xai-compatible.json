{
  "id": "xai-compatible",
  "name": "xAI OpenAI-compatible harness",
  "summary": "Route normal xAI HTTPS traffic through DAM.",
  "provider": "openai-compatible",
  "traffic_app_ids": ["xai-api"],
  "connect_args": [
    "--target-name",
    "xai",
    "--provider",
    "openai-compatible",
    "--upstream",
    "https://api.x.ai",
    "--network-mode",
    "tun",
    "--trust-mode",
    "local_ca"
  ],
  "settings": [
    {
      "key": "HTTPS_PROXY",
      "value": "{{proxy_url}}",
      "description": "HTTPS proxy for explicit-proxy fallback"
    },
    {
      "key": "HTTP_PROXY",
      "value": "{{proxy_url}}",
      "description": "HTTP proxy for explicit-proxy fallback"
    }
  ],
  "commands": [
    {
      "label": "Start DAM with xAI upstream",
      "command": [
        "dam",
        "connect",
        "--profile",
        "xai-compatible",
        "--network-mode",
        "tun",
        "--trust-mode",
        "local_ca"
      ]
    }
  ],
  "notes": [
    "The harness still owns provider credentials. Configure its xAI API key through the harness's normal secret mechanism.",
    "This profile selects the upstream target while keeping the harness on the normal xAI endpoint through DAM proxy routing."
  ],
  "automation": "connect_preset"
}
