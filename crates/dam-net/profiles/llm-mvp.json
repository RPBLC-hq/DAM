{
  "version": 1,
  "name": "llm_mvp",
  "default_action": "bypass",
  "apps": [
    {
      "id": "openai-api",
      "name": "OpenAI API",
      "enabled": true,
      "priority": 0,
      "match": {
        "domains": ["api.openai.com"],
        "ports": [443],
        "protocols": ["https", "web_socket"]
      },
      "action": "inspect",
      "adapter": "http",
      "provider": "openai-compatible",
      "target_name": "openai",
      "upstream": "https://api.openai.com",
      "auth": {
        "caller_headers": ["authorization"],
        "inject": {
          "header": "authorization",
          "scheme": "Bearer",
          "strip_headers": ["authorization"]
        }
      },
      "steps": [
        {"id": "detect", "kind": "detect_sensitive_data", "direction": "outbound"},
        {"id": "consent", "kind": "apply_consents", "direction": "outbound"},
        {"id": "tokenize", "kind": "replace_sensitive_data", "direction": "outbound"}
      ],
      "outbound": {"filter": {"default_action": "tokenize"}},
      "inbound": {"resolve_references": false, "protect_sensitive_data": true}
    },
    {
      "id": "anthropic-api",
      "name": "Anthropic API",
      "enabled": true,
      "priority": 0,
      "match": {
        "domains": ["api.anthropic.com"],
        "ports": [443],
        "protocols": ["https", "web_socket"]
      },
      "action": "inspect",
      "adapter": "http",
      "provider": "anthropic",
      "target_name": "anthropic",
      "upstream": "https://api.anthropic.com",
      "auth": {
        "caller_headers": ["x-api-key", "authorization"],
        "inject": {
          "header": "x-api-key",
          "strip_headers": ["x-api-key", "authorization"]
        }
      },
      "steps": [
        {"id": "detect", "kind": "detect_sensitive_data", "direction": "outbound"},
        {"id": "consent", "kind": "apply_consents", "direction": "outbound"},
        {"id": "tokenize", "kind": "replace_sensitive_data", "direction": "outbound"}
      ],
      "outbound": {"filter": {"default_action": "tokenize"}},
      "inbound": {"resolve_references": false, "protect_sensitive_data": true}
    },
    {
      "id": "chatgpt-codex",
      "name": "ChatGPT Codex",
      "enabled": true,
      "priority": 0,
      "match": {
        "domains": ["chatgpt.com", "ab.chatgpt.com"],
        "ports": [443],
        "protocols": ["https", "web_socket"]
      },
      "action": "inspect",
      "adapter": "web_socket",
      "provider": "openai-compatible",
      "target_name": "chatgpt-codex",
      "upstream": "https://chatgpt.com",
      "steps": [
        {"id": "detect", "kind": "detect_sensitive_data", "direction": "outbound"},
        {"id": "consent", "kind": "apply_consents", "direction": "outbound"},
        {"id": "tokenize", "kind": "replace_sensitive_data", "direction": "outbound"}
      ],
      "outbound": {"filter": {"default_action": "tokenize"}},
      "inbound": {"resolve_references": false}
    }
  ]
}
