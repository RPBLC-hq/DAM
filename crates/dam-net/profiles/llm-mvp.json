{
  "version": 1,
  "name": "llm_mvp",
  "default_action": "bypass",
  "apps": [
    {
      "id": "openai-api",
      "name": "OpenAI API",
      "enabled": true,
      "priority": 0,
      "match": {
        "domains": ["api.openai.com"],
        "ports": [443],
        "protocols": ["https", "web_socket"]
      },
      "action": "inspect",
      "adapter": "http",
      "provider": "openai-compatible",
      "target_name": "openai",
      "upstream": "https://api.openai.com",
      "auth": {
        "caller_headers": ["authorization"],
        "inject": {
          "header": "authorization",
          "scheme": "Bearer",
          "strip_headers": ["authorization"]
        }
      },
      "steps": [
        {"id": "detect", "kind": "detect_sensitive_data", "direction": "outbound"},
        {"id": "consent", "kind": "apply_consents", "direction": "outbound"},
        {"id": "redact", "kind": "replace_sensitive_data", "direction": "outbound"}
      ],
      "outbound": {"filter": {"default_action": "tokenize"}},
      "inbound": {"resolve_references": true, "protect_sensitive_data": true}
    },
    {
      "id": "anthropic-api",
      "name": "Anthropic API",
      "enabled": true,
      "priority": 0,
      "match": {
        "domains": ["api.anthropic.com"],
        "ports": [443],
        "protocols": ["https", "web_socket"]
      },
      "action": "inspect",
      "adapter": "http",
      "provider": "anthropic",
      "target_name": "anthropic",
      "upstream": "https://api.anthropic.com",
      "auth": {
        "caller_headers": ["x-api-key", "authorization"],
        "inject": {
          "header": "x-api-key",
          "strip_headers": ["x-api-key", "authorization"]
        }
      },
      "steps": [
        {"id": "detect", "kind": "detect_sensitive_data", "direction": "outbound"},
        {"id": "consent", "kind": "apply_consents", "direction": "outbound"},
        {"id": "redact", "kind": "replace_sensitive_data", "direction": "outbound"}
      ],
      "outbound": {"filter": {"default_action": "tokenize"}},
      "inbound": {"resolve_references": true, "protect_sensitive_data": true}
    },
